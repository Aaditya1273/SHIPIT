# 0G STORAGE SERVICE CONFIGURATION
# This file contains the essential configurations for the Beyond-The-Fog Unified Core.

# --- SERVER CONFIG ---
PORT=3002
NODE_ENV=development

# --- 0G NETWORK CONFIG (Newton Testnet) ---
# Your account private key (Must have testnet tokens for transactions)
PRIVATE_KEY=your_private_key_here

# 0G Newton RPC Endpoint
BLOCKCHAIN_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage Indexer/Gossip RPC
# This is used for checking file status and basic interaction
GAS_PRICE_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai

# 0G Storage Node RPC
# The direct gRPC endpoint for data dispersal (DA)
ZGS_NODE_RPC=http://standard-storage-node-testnet.0g.ai:5678

# --- CONTRACT ADDRESSES (Newton Testnet) ---
# UserRegistry: Anchors player identity and dialogue root hashes
USER_REGISTRY_ADDRESS=0x6b542A9361A7dd16c0b6396202A192326154a1e2

# INFT Contract: Manages evolved AI companions
INFT_CONTRACT_ADDRESS=0x494d8E03605E297F936a6F244B7BcD03e4563D7E

# --- AI COMPUTE (0G Compute / LLM) ---
# LLM Endpoint (e.g., Llama 3 on 0G Compute Broker)
LLM_API_URL=https://api.0g-compute.ai/v1
LLM_API_KEY=your_compute_key_here

# --- ASSET CIDs (0G Storage Root Hashes) ---
# Replace these with the actual root hashes uploaded to 0G Storage
NEWBORN_IMAGE_CID=0x...
CURIOUS_IMAGE_CID=0x...
MASTER_IMAGE_CID=0x...
WISE_IMAGE_CID=0x...
SAVIOR_IMAGE_CID=0x...
